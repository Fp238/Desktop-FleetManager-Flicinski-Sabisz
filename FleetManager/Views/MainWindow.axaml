<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:FleetManager.Views"
        xmlns:vm="clr-namespace:FleetManager.ViewModels"
        x:Class="FleetManager.MainWindow"
        Width="450" 
        Height="700"
        Title="Fleet Manager"
        x:DataType="vm:MainWindowViewModel"
        >
    <ListBox ItemsSource="{Binding Vehicles}">
        <ListBox.ItemTemplate>
            <DataTemplate>
                <local:VehicleItemView DataContext="{Binding}" />
            </DataTemplate>
        </ListBox.ItemTemplate>
    </ListBox>
</Window>